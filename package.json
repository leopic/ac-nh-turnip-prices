{
  "name": "ac-nh-turnip-prices",
  "version": "2.0.0",
  "description": "Turnip price predictor for Animal Crossing: New Horizons",
  "main": "service-worker.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "npx serve .",
    "prepare": "git config core.hooksPath .githooks",
    "deploy": "rsync -avz --delete --exclude-from='rsync-exclude.txt' -e 'ssh -i ~/.ssh/dreamhost_turnip_deploy' ./ dh_turnip_prophet@turnip-prophet.leonardopicado.com:/home/dh_turnip_prophet/turnip-prophet.leonardopicado.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leopic/ac-nh-turnip-prices.git"
  },
  "keywords": [
    "animal-crossing",
    "turnip-prices",
    "predictor"
  ],
  "author": "Mike Bryant, leopic",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/leopic/ac-nh-turnip-prices/issues"
  },
  "homepage": "https://github.com/leopic/ac-nh-turnip-prices#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "vitest": "^4.1.0"
  }
}
